@using MyAcademy_JWT.Entities
@model List<Package>

@{
    ViewData["Title"] = "Upgrade Plan";
    Layout = "~/Views/Shared/_UILayout.cshtml";
    var currentId = (int?)ViewBag.CurrentPackageId;
}

<div class="page-container p-5">
    <h2 class="text-white mb-4">Upgrade Your Plan</h2>

    <div class="row">

        @foreach (var package in Model)
        {
            var isCurrent = currentId == package.Id;

            <div class="col-md-4 mb-4">
                <div class="card bg-dark text-white shadow border-0 h-100">
                    <div class="card-body text-center">

                        <h4>@package.Name</h4>

                        <p class="text-muted">
                            Access Level: @package.MinLevel
                        </p>

                        @if (isCurrent)
                        {
                            <span class="badge badge-success mb-3">
                                Current Plan
                            </span>
                        }
                        else
                        {
                            <form asp-action="Upgrade" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden"
                                       name="packageId"
                                       value="@package.Id" />

                                <button class="btn btn-warning mt-3">
                                    Upgrade
                                </button>
                            </form>
                        }

                    </div>
                </div>
            </div>
        }

    </div>
</div>