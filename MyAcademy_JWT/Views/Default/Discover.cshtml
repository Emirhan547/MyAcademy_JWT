@model List<SongCardViewModel>

@{
    ViewData["Title"] = "Discover";
    Layout = "~/Views/Shared/_UILayout.cshtml";
}
@if (ViewBag.Recommendations != null)
{
    <div class="mb-5">
        <h3 class="text-white mb-4">
            🤖 Recommended For You
        </h3>

        <div class="row">
            @foreach (var song in ViewBag.Recommendations)
            {
                <div class="col-md-3 mb-3">
                    <div class="card bg-secondary text-white border-0 shadow">

                        <div class="card-body text-center">
                            <h6>@song.Title</h6>
                            <small>🔥 @song.PlayCount plays</small>

                            <div class="mt-3">
                                <button class="btn btn-sm btn-light play-btn"
                                        data-id="@song.Id">
                                    ▶ Play
                                </button>
                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>
    </div>
}
<div class="page-container p-5">
    <h2 class="text-white mb-4">Discover Music</h2>

    <div class="row">

        @foreach (var song in Model)
        {
            <div class="col-md-3 mb-4">
                <div class="card bg-dark text-white border-0 shadow position-relative">

                    <img src="@(song.CoverImageUrl ?? "/Bepop/assets/img/default.jpg")"
                         class="card-img-top"
                         style="height:200px; object-fit:cover;" />

                    @if (!song.CanAccess)
                    {
                        <div class="position-absolute w-100 h-100 d-flex align-items-center justify-content-center"
                             style="background:rgba(0,0,0,0.6); top:0;">
                            <div class="text-center">
                                <h3>🔒</h3>
                                <p>Premium Required</p>
                                <a asp-controller="Package"
                                   asp-action="Upgrade"
                                   class="btn btn-warning btn-sm">
                                    Upgrade
                                </a>
                            </div>
                        </div>
                    }

                    <div class="card-body text-center">
                        <h6>@song.Title</h6>
                        <small class="text-muted">@song.ArtistName</small>

                        <div class="mt-3">
                            @if (song.CanAccess)
                            {
                                <button class="btn btn-primary btn-sm play-btn"
                                        data-id="@song.Id">
                                    ▶ Play
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-secondary btn-sm" disabled>
                                    Locked
                                </button>
                            }
                        </div>
                    </div>

                </div>
            </div>
        }

    </div>
</div>
@section Scripts {
    <script>
        document.querySelectorAll(".play-btn").forEach(btn => {
            btn.addEventListener("click", async function () {
                const id = this.getAttribute("data-id");

                const audio = new Audio(`/api/songs/${id}/stream`);
                audio.play();
            });
        });
    </script>
}