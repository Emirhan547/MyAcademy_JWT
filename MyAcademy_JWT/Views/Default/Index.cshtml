@model HomeViewModel
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_UILayout.cshtml";
}

<div class="page-container p-5">
	<div class="text-center mb-5">
		<h1 class="display-4 font-weight-bold text-white">MyAcademy Music</h1>
		<p class="text-muted">Canlı verilerle müzik platformunu keşfet.</p>
		<a asp-controller="Default" asp-action="Discover" class="btn btn-md gd-primary text-white m-2">Discover</a>
	</div>

	<div class="row mb-4">
		<div class="col-md-4 mb-3">
			<div class="card bg-dark text-white border-0 shadow h-100">
				<div class="card-body text-center">
					<h6 class="text-muted">Toplam Şarkı</h6>
					<h2>@Model.TotalSongCount</h2>
				</div>
			</div>
		</div>
		<div class="col-md-4 mb-3">
			<div class="card bg-dark text-white border-0 shadow h-100">
				<div class="card-body text-center">
					<h6 class="text-muted">Toplam Sanatçı</h6>
					<h2>@Model.TotalArtistCount</h2>
				</div>
			</div>
		</div>
		<div class="col-md-4 mb-3">
			<div class="card bg-dark text-white border-0 shadow h-100">
				<div class="card-body text-center">
					<h6 class="text-muted">Toplam Dinlenme</h6>
					<h2>@Model.TotalPlayCount</h2>
				</div>
			</div>
		</div>
	</div>

	<div class="row">
		<div class="col-lg-8 mb-4">
			<h3 class="text-white mb-3">🔥 Trend Şarkılar</h3>
			<div class="row">
				@foreach (var song in Model.TrendingSongs)
				{
					<div class="col-md-6 mb-3">
						<div class="card bg-dark text-white border-0 shadow h-100">
							<img src="@(song.CoverImageUrl ?? "/Bepop/assets/img/default.jpg")"
								 class="card-img-top"
								 style="height:170px; object-fit:cover;" />
							<div class="card-body">
								<h6 class="mb-1">@song.Title</h6>
								<small class="text-muted d-block">@song.ArtistName</small>
								<small class="text-warning">🔥 @song.PlayCount plays</small>
							</div>
						</div>
					</div>
				}
			</div>
		</div>

		<div class="col-lg-4 mb-4">
			<h3 class="text-white mb-3">🎤 Popüler Sanatçılar</h3>
			<div class="card bg-dark text-white border-0 shadow">
				<ul class="list-group list-group-flush">
					@foreach (var artist in Model.PopularArtists)
					{
						<li class="list-group-item bg-dark text-white d-flex justify-content-between align-items-center border-secondary">
							<div>
								<div class="font-weight-bold">@artist.Name</div>
								<small class="text-muted">@artist.SongCount şarkı</small>
							</div>
							<span class="badge badge-warning">@artist.TotalPlayCount</span>
						</li>
					}
				</ul>
			</div>
		</div>
	</div>
</div>

