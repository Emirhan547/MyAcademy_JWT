@model LoginViewModel

@{
    ViewData["Title"] = "Sign In";
    Layout = "~/Views/Shared/_UILayout.cshtml";
}

<div class="layout-row bg-dark" style="min-height:100vh;">
    <div class="d-flex flex-column flex w-100">
        <div class="row no-gutters h-100">

            <!-- LEFT IMAGE -->
            <div class="col-md-6 bg-dark bg-img"
                 style="background-image:url('@Url.Content("~/Bepop/assets/img/b6.jpg")');
                        background-size:cover;
                        background-position:center;">
                <div class="p-4 p-md-5 d-flex flex-column h-100">
                    <h4 class="mb-3 text-white">Bepop</h4>
                    <div class="text-fade">Music Web Application</div>
                    <div class="flex"></div>
                </div>
            </div>

            <!-- RIGHT LOGIN -->
            <div class="col-md-6 d-flex align-items-center">
                <div class="p-4 p-md-5 w-100" style="max-width:450px; margin:auto;">

                    <h5>Welcome back</h5>
                    <p>
                        <small class="text-muted">
                            Login to manage your account
                        </small>
                    </p>

                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <form asp-action="Login" method="post">

                        @Html.AntiForgeryToken()

                        <div class="form-group">
                            <label>Email</label>
                            <input asp-for="Email"
                                   class="form-control"
                                   placeholder="Enter email" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label>Password</label>
                            <input asp-for="Password"
                                   class="form-control"
                                   placeholder="Password" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="checkbox mb-3">
                            <label class="ui-check">
                                <input type="checkbox">
                                <i></i> Remember me
                            </label>
                        </div>

                        <button type="submit"
                                class="btn btn-primary btn-block mb-4">
                            Sign in
                        </button>

                        <div class="text-center">
                            Do not have an account?
                            <a asp-controller="Account"
                               asp-action="Register"
                               class="text-primary">
                                Sign up
                            </a>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}